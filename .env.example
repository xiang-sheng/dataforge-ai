# ============================================================
# DataForge-AI Environment Configuration
# Copy this file to .env and fill in the actual values.
#
# All variables are prefixed with DATAFORGE_ to match the
# env_prefix in src/config/settings.py (AppSettings).
# ============================================================

# --------------------------------------------------
# Application
# --------------------------------------------------
DATAFORGE_APP_NAME=dataforge-ai
DATAFORGE_DEBUG=true
DATAFORGE_LOG_LEVEL=INFO

# --------------------------------------------------
# Internal Metadata Database (PostgreSQL via asyncpg)
# --------------------------------------------------
DATAFORGE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dataforge
DATAFORGE_DATABASE_ECHO=false
DATAFORGE_DATABASE_POOL_SIZE=20
DATAFORGE_DATABASE_MAX_OVERFLOW=10

# --------------------------------------------------
# Redis (caching & pub/sub)
# --------------------------------------------------
DATAFORGE_REDIS_URL=redis://localhost:6379/0
DATAFORGE_REDIS_KEY_PREFIX=dataforge:

# --------------------------------------------------
# LLM Provider Selection
# --------------------------------------------------
# Supported: openai, azure_openai, ollama, tongyi, deepseek, local
DATAFORGE_LLM_PROVIDER=ollama

# --------------------------------------------------
# OpenAI / LLM Configuration
# --------------------------------------------------
DATAFORGE_OPENAI_API_KEY=sk-your-api-key-here
DATAFORGE_OPENAI_API_BASE=https://api.openai.com/v1
DATAFORGE_OPENAI_MODEL=gpt-4o
DATAFORGE_OPENAI_FALLBACK_MODEL=gpt-4o-mini
DATAFORGE_OPENAI_MAX_TOKENS=4096
DATAFORGE_OPENAI_TEMPERATURE=0.3
DATAFORGE_OPENAI_REQUEST_TIMEOUT=60
DATAFORGE_OPENAI_MAX_RETRIES=3

# --------------------------------------------------
# Ollama (Local LLM) Configuration
# --------------------------------------------------
# Start Ollama:  ollama serve
# Pull a model:  ollama pull qwen2.5:14b
DATAFORGE_OLLAMA_BASE_URL=http://localhost:11434
DATAFORGE_OLLAMA_MODEL=qwen2.5:14b
DATAFORGE_OLLAMA_TEMPERATURE=0.1
DATAFORGE_OLLAMA_REQUEST_TIMEOUT=300

# --------------------------------------------------
# DuckDB Local Sandbox (lightweight verification)
# --------------------------------------------------
DATAFORGE_DUCKDB_ENABLED=true
DATAFORGE_DUCKDB_DATABASE_PATH=:memory:
DATAFORGE_DUCKDB_VERIFY_SAMPLE_ROWS=100
DATAFORGE_DUCKDB_MEMORY_LIMIT_MB=512

# --------------------------------------------------
# Convention File
# --------------------------------------------------
# Path to default table creation convention YAML file
DATAFORGE_CONVENTION_FILE_PATH=conventions/default_convention.yaml

# --------------------------------------------------
# Security / CORS
# --------------------------------------------------
DATAFORGE_CORS_ORIGINS=http://localhost:3000,http://localhost:8000
DATAFORGE_CORS_ALLOW_CREDENTIALS=true

# --------------------------------------------------
# Query Execution Limits
# --------------------------------------------------
DATAFORGE_QUERY_TIMEOUT_SECONDS=300
DATAFORGE_QUERY_MAX_ROWS=10000

# --------------------------------------------------
# JWT / Auth (future use)
# --------------------------------------------------
# DATAFORGE_JWT_SECRET_KEY=change-me-to-a-random-secret
# DATAFORGE_JWT_ALGORITHM=HS256
# DATAFORGE_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --------------------------------------------------
# Observability (optional)
# --------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# SENTRY_DSN=
# PROMETHEUS_ENABLED=false
