# ============================================================
# DataForge-AI Environment Configuration
# Copy this file to .env and fill in the actual values
# ============================================================

# --------------------------------------------------
# Application
# --------------------------------------------------
APP_NAME=dataforge-ai
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_SECRET_KEY=change-me-to-a-random-secret

# --------------------------------------------------
# Internal Metadata Database (PostgreSQL via asyncpg)
# --------------------------------------------------
METADATA_DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dataforge
METADATA_DB_ECHO=false
METADATA_DB_POOL_SIZE=20
METADATA_DB_MAX_OVERFLOW=10

# --------------------------------------------------
# Redis (caching & pub/sub)
# --------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PREFIX=dataforge:

# --------------------------------------------------
# OpenAI / LLM Configuration
# --------------------------------------------------
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.3
OPENAI_TIMEOUT=60

# --------------------------------------------------
# Target Data Source Defaults (optional overrides)
# These are used as fallback connection parameters.
# Actual connections are managed via the API / UI.
# --------------------------------------------------

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DATABASE=

# SQL Server
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=
MSSQL_DATABASE=

# Oracle
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_USER=system
ORACLE_PASSWORD=
ORACLE_SERVICE_NAME=ORCL

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# Apache Doris (MySQL protocol compatible)
DORIS_HOST=localhost
DORIS_PORT=9030
DORIS_USER=root
DORIS_PASSWORD=
DORIS_DATABASE=

# Hive
HIVE_HOST=localhost
HIVE_PORT=10000
HIVE_USER=hive
HIVE_PASSWORD=
HIVE_DATABASE=default
HIVE_AUTH=NOSASL

# --------------------------------------------------
# Security / CORS
# --------------------------------------------------
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=true

# --------------------------------------------------
# Observability (optional)
# --------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# SENTRY_DSN=
# PROMETHEUS_ENABLED=false
